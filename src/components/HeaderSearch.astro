---
import { Icon } from "astro-icon/components";
import Search from "./Search";
---
   
<Search id="search-component" client:load>
	<Icon slot="iconSearch" name="mdi:search" class="text-(--foreground) text-2xl mx-[5px]"/>      
	<Icon slot="btnClose" name="mdi:close" id="search-close" class="text-(--foreground) text-2xl mx-[5px]"/>  
	<Icon slot="btnTags" name="mdi:tags" class="text-(--foreground) text-2xl mx-[5px]"/>   
	<Icon slot="btnFilter" name="mdi:filter-variant" class="text-(--foreground) text-2xl mx-[5px]"/>    
	<Icon slot="btnFolder"name="mdi:folder-outline" class="text-(--foreground) text-2xl mx-[5px]"/>  
	<Icon slot="btnMenu" name="mdi:more-vert" class="text-(--foreground) text-2xl mx-[5px]"/>  
</Search>
