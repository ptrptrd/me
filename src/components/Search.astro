---
import { Icon } from "astro-icon/components";
---

<div id="input-search" class="w-full min-w-[200px] flex">    
	<Icon name="mdi:search" class="text-(--foreground) text-2xl mx-[5px]"/>      
	<input type="text" class="w-full border-transparent focus:outline-none text-(--foreground)" placeholder="Search..." />
	<Icon name="mdi:tags" class="text-(--foreground) text-2xl mx-[5px]"/>   
	<Icon name="mdi:filter-variant" class="text-(--foreground) text-2xl mx-[5px]"/>    
</div>
