---
import { Icon } from "astro-icon/components";

const today = new Date();
---

<footer class="w-full h-1/20 min-h-[80px] bg-(--panel-main) text-(--panel-main-foreground) flex items-center justify-center">
	<span>&copy; {today.getFullYear()}</span>
	<a href="https://github.com/ptrptrd" target="_blank" class="ml-[5px] flex">
		<span>ptrptrd</span>
		<Icon name="mdi:github" class="text-(--foreground) text-2xl mx-[5px]"></Icon>
	</a>
</footer>
